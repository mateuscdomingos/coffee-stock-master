generator client {
  provider = "prisma-client"
  output   = "./generated"
}

datasource db {
  provider = "postgresql"
}

model Store {
  id                   String   @id
  name                 String
  monthlyBudgetInCents Int
  orders               Order[]
  createdAt            DateTime @default(now())
  userId               String

  user User @relation(fields: [userId], references: [id])
  products Product[]
}

model Order {
  id                 String   @id @default(uuid())
  storeId            String
  employeeId         String
  status             String
  totalAmountInCents Int
  createdAt          DateTime @default(now())

  items OrderItem[]
  store Store       @relation(fields: [storeId], references: [id])
  user  User        @relation(fields: [employeeId], references: [id])

  @@index([storeId, createdAt])
}

model OrderItem {
  id               String @id @default(uuid())
  orderId          String
  productId        String
  name             String
  quantity         Int
  unitPriceInCents Int

  order Order @relation(fields: [orderId], references: [id])
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())

  orders Order[]
  stores Store[]
}

model Product {
  id                   String   @id @default(uuid())
  name                 String
  roast                String
  priceInCents         Int
  stockQuantity        Int      @default(0)
  minimumStockQuantity Int      @default(0)
  unit                 String
  
  storeId              String
  store                Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  createdAt            DateTime @default(now())

  @@index([storeId])
}
